{
	"name": "bun-react-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
		"dev:frontend": "vite --config frontend/vite.config.ts",
		"dev:backend": "bun --hot backend/src/index.ts",
		"build": "tsr generate && tsc && vite build",
		"preview": "vite preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit .",
		"format": "biome format .",
		"format:check": "biome format ."
	},
	"dependencies": {
		"@tanstack/react-router": "^1.166.3",
		"axios": "^1.13.6",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9",
		"react": "^19",
		"react-dom": "^19",
		"tailwindcss": "^4.2.1",
		"valibot": "^1.2.0",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/router-plugin": "^1.166.3",
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5.1.4",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.31.10",
		"vite": "^7.3.1"
	}
}
